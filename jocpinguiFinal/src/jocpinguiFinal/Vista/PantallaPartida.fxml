<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="jocpinguiFinal.Vista.PantallaPartida" stylesheets="@PantallaPartida.css">

    <top>
        <MenuBar styleClass="menu-bar">
            <menus>
                <Menu mnemonicParsing="false" text="JOC DEL PENGUI" />
            </menus>
        </MenuBar>
    </top>

    <center>
        <VBox fx:id="contentPane" spacing="18" styleClass="content-pane">
            <Label fx:id="titleLabel" text="CONFIGURACIÓN DE PARTIDA" />
            <Label fx:id="infoText" text="Ingresa los nombres y colores de los jugadores (mínimo 1, máximo 4)" />

            <!-- Jugador 1 -->
            <HBox spacing="10" styleClass="player-row">
                <VBox spacing="5" style="-fx-min-width: 250;">
                    <Label style="-fx-font-weight: bold;" text="Jugador 1" />
                    <TextField fx:id="player1Field" promptText="Nombre..." />
                </VBox>
                <VBox spacing="5" style="-fx-min-width: 150;">
                    <Label style="-fx-font-weight: bold;" text="Color" />
                    <ComboBox fx:id="color1Combo" prefWidth="140" />
                </VBox>
            </HBox>

            <!-- Jugador 2 -->
            <HBox spacing="10" styleClass="player-row">
                <VBox spacing="5" style="-fx-min-width: 250;">
                    <Label style="-fx-font-weight: bold;" text="Jugador 2 (Opcional)" />
                    <TextField fx:id="player2Field" promptText="Nombre..." />
                </VBox>
                <VBox spacing="5" style="-fx-min-width: 150;">
                    <Label style="-fx-font-weight: bold;" text="Color" />
                    <ComboBox fx:id="color2Combo" prefWidth="140" />
                </VBox>
            </HBox>

            <!-- Jugador 3 -->
            <HBox spacing="10" styleClass="player-row">
                <VBox spacing="5" style="-fx-min-width: 250;">
                    <Label style="-fx-font-weight: bold;" text="Jugador 3 (Opcional)" />
                    <TextField fx:id="player3Field" promptText="Nombre..." />
                </VBox>
                <VBox spacing="5" style="-fx-min-width: 150;">
                    <Label style="-fx-font-weight: bold;" text="Color" />
                    <ComboBox fx:id="color3Combo" prefWidth="140" />
                </VBox>
            </HBox>

            <!-- Jugador 4 -->
            <HBox spacing="10" styleClass="player-row">
                <VBox spacing="5" style="-fx-min-width: 250;">
                    <Label style="-fx-font-weight: bold;" text="Jugador 4 (Opcional)" />
                    <TextField fx:id="player4Field" promptText="Nombre..." />
                </VBox>
                <VBox spacing="5" style="-fx-min-width: 150;">
                    <Label style="-fx-font-weight: bold;" text="Color" />
                    <ComboBox fx:id="color4Combo" prefWidth="140" />
                </VBox>
            </HBox>

            <!-- Botones Save/Load -->
            <HBox spacing="12" styleClass="button-row">
                <Button fx:id="loadGameButton" onAction="#handleLoadGame" styleClass="secondary-button" text="Cargar Partida" />
                <Button fx:id="saveGameButton" onAction="#handleSaveGame" styleClass="secondary-button" text="Guardar Config" />
            </HBox>

            <!-- Botones Principal -->
            <HBox spacing="12" styleClass="button-row">
                <Button fx:id="startGameButton" onAction="#handleStartGame" styleClass="action-button" text="Iniciar Partida" />
                <Button fx:id="backButton" onAction="#handleBack" styleClass="secondary-button" text="Atrás" />
            </HBox>

        </VBox>
    </center>

</BorderPane>
