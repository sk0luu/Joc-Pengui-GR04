<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>

<StackPane
    prefHeight="720.0" prefWidth="1280.0"
    styleClass="root"
    stylesheets="@PantallaPartida.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="jocpinguiFinal.Vista.PantallaPartida">

    <!-- Tarjeta de configuración centrada -->
    <VBox fx:id="contentPane" spacing="14" styleClass="card"
          maxWidth="560" maxHeight="-Infinity" alignment="CENTER">
        <padding>
            <Insets top="36" bottom="36" left="36" right="36"/>
        </padding>

        <!-- Título -->
        <Label fx:id="titleLabel" styleClass="title" text="CONFIGURACION DE PARTIDA" maxWidth="Infinity"/>
        <Label fx:id="infoText" styleClass="subtitle"
               text="Nombres y colores de los jugadores (min. 1, max. 4)"
               wrapText="true" maxWidth="Infinity"/>

        <Region prefHeight="6"/>

        <!-- Jugador 1 -->
        <HBox spacing="10" styleClass="player-row">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Jugador 1"/>
                <TextField fx:id="player1Field" promptText="Nombre..." styleClass="field"/>
            </VBox>
            <VBox spacing="4">
                <Label styleClass="field-label" text="Color"/>
                <ComboBox fx:id="color1Combo" prefWidth="130" styleClass="field"/>
            </VBox>
        </HBox>

        <!-- Jugador 2 -->
        <HBox spacing="10" styleClass="player-row">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Jugador 2 (Opcional)"/>
                <TextField fx:id="player2Field" promptText="Nombre..." styleClass="field"/>
            </VBox>
            <VBox spacing="4">
                <Label styleClass="field-label" text="Color"/>
                <ComboBox fx:id="color2Combo" prefWidth="130" styleClass="field"/>
            </VBox>
        </HBox>

        <!-- Jugador 3 -->
        <HBox spacing="10" styleClass="player-row">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Jugador 3 (Opcional)"/>
                <TextField fx:id="player3Field" promptText="Nombre..." styleClass="field"/>
            </VBox>
            <VBox spacing="4">
                <Label styleClass="field-label" text="Color"/>
                <ComboBox fx:id="color3Combo" prefWidth="130" styleClass="field"/>
            </VBox>
        </HBox>

        <!-- Jugador 4 -->
        <HBox spacing="10" styleClass="player-row">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Jugador 4 (Opcional)"/>
                <TextField fx:id="player4Field" promptText="Nombre..." styleClass="field"/>
            </VBox>
            <VBox spacing="4">
                <Label styleClass="field-label" text="Color"/>
                <ComboBox fx:id="color4Combo" prefWidth="130" styleClass="field"/>
            </VBox>
        </HBox>

        <!-- Opcion Foca -->
        <CheckBox fx:id="focaCheckBox" text="Incluir la Foca" selected="true" styleClass="foca-check"/>

        <Region prefHeight="4"/>

        <!-- Botón Cargar -->
        <Button fx:id="loadGameButton" onAction="#handleLoadGame"
                styleClass="secondary-btn" text="Cargar Partida" maxWidth="Infinity"/>

        <!-- Botones Iniciar / Atras -->
        <HBox spacing="12">
            <Button fx:id="startGameButton" onAction="#handleStartGame"
                    styleClass="primary-btn" text="Iniciar Partida" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Button fx:id="backButton" onAction="#handleBack"
                    styleClass="secondary-btn" text="Atras" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        </HBox>

    </VBox>

    <!-- Panel de Ranking (derecha, superpuesto sobre el fondo) -->
    <VBox fx:id="rankingPanel" styleClass="ranking-card"
          maxWidth="300" maxHeight="-Infinity"
          alignment="TOP_CENTER" spacing="0"
          StackPane.alignment="CENTER_RIGHT">
        <padding>
            <Insets top="0" bottom="0" left="0" right="40"/>
        </padding>
        <VBox styleClass="ranking-inner" spacing="10">
            <padding>
                <Insets top="24" bottom="24" left="20" right="20"/>
            </padding>
            <Label text="🏆  RANKING" styleClass="ranking-title" maxWidth="Infinity"/>
            <Label text="Top victorias globales" styleClass="ranking-subtitle" maxWidth="Infinity"/>
            <Region prefHeight="6"/>
            <VBox fx:id="rankingBox" spacing="6"/>
            <Label fx:id="rankingEmptyLabel" text="Cargando ranking..."
                   styleClass="ranking-empty" maxWidth="Infinity" wrapText="true"/>
        </VBox>
    </VBox>

</StackPane>
