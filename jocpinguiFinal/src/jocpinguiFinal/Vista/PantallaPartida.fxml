<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="jocpinguiFinal.Vista.PantallaPartida">

    <top>
        <MenuBar>
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem fx:id="newGame" mnemonicParsing="false" onAction="#handleNewGame" text="New" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="saveGame" mnemonicParsing="false" onAction="#handleSaveGame" text="Save" />
                        <MenuItem fx:id="loadGame" mnemonicParsing="false" onAction="#handleLoadGame" text="Load" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="quitGame" mnemonicParsing="false" onAction="#handleQuitGame" text="Quit" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <Label fx:id="titleLabel" text="CONFIGURACIÓN DE PARTIDA" style="-fx-font-size: 18; -fx-font-weight: bold;" />
            <Label fx:id="infoText" text="Ingresa los nombres y colores de los jugadores (mínimo 1, máximo 4)" />

            <!-- Jugador 1 -->
            <HBox spacing="10">
                <VBox spacing="5" style="-fx-min-width: 250;">
                    <Label text="Jugador 1" style="-fx-font-weight: bold;" />
                    <TextField fx:id="player1Field" promptText="Nombre..." />
                </VBox>
                <VBox spacing="5" style="-fx-min-width: 150;">
                    <Label text="Color" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="color1Combo" prefWidth="140" />
                </VBox>
            </HBox>

            <!-- Jugador 2 -->
            <HBox spacing="10">
                <VBox spacing="5" style="-fx-min-width: 250;">
                    <Label text="Jugador 2 (Opcional)" style="-fx-font-weight: bold;" />
                    <TextField fx:id="player2Field" promptText="Nombre..." />
                </VBox>
                <VBox spacing="5" style="-fx-min-width: 150;">
                    <Label text="Color" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="color2Combo" prefWidth="140" />
                </VBox>
            </HBox>

            <!-- Jugador 3 -->
            <HBox spacing="10">
                <VBox spacing="5" style="-fx-min-width: 250;">
                    <Label text="Jugador 3 (Opcional)" style="-fx-font-weight: bold;" />
                    <TextField fx:id="player3Field" promptText="Nombre..." />
                </VBox>
                <VBox spacing="5" style="-fx-min-width: 150;">
                    <Label text="Color" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="color3Combo" prefWidth="140" />
                </VBox>
            </HBox>

            <!-- Jugador 4 -->
            <HBox spacing="10">
                <VBox spacing="5" style="-fx-min-width: 250;">
                    <Label text="Jugador 4 (Opcional)" style="-fx-font-weight: bold;" />
                    <TextField fx:id="player4Field" promptText="Nombre..." />
                </VBox>
                <VBox spacing="5" style="-fx-min-width: 150;">
                    <Label text="Color" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="color4Combo" prefWidth="140" />
                </VBox>
            </HBox>

            <!-- Botones Save/Load -->
            <HBox spacing="10" style="-fx-padding: 15 0 0 0;">
                <Button fx:id="loadGameButton" text="Cargar Partida" onAction="#handleLoadGame" style="-fx-padding: 10; -fx-font-size: 12;" />
                <Button fx:id="saveGameButton" text="Guardar Config" onAction="#handleSaveGame" style="-fx-padding: 10; -fx-font-size: 12;" />
            </HBox>

            <!-- Botones Principal -->
            <HBox spacing="10" style="-fx-padding: 15 0 0 0;">
                <Button fx:id="startGameButton" text="Iniciar Partida" onAction="#handleStartGame" style="-fx-padding: 10; -fx-font-size: 12; -fx-min-width: 180;" />
                <Button fx:id="backButton" text="Atrás" onAction="#handleBack" style="-fx-padding: 10; -fx-font-size: 12; -fx-min-width: 180;" />
            </HBox>

        </VBox>
    </center>

</BorderPane>
