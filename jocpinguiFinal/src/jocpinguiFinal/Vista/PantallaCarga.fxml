<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="videoContainer"
           prefHeight="720.0" prefWidth="1280.0"
           stylesheets="@PantallaCarga.css"
           styleClass="root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="jocpinguiFinal.Vista.PantallaCarga">

    <!--
        El MediaView del video se inserta dinámicamente en el índice 0
        desde PantallaCarga.java, quedando detrás de este VBox.
    -->

    <!-- Overlay oscuro semitransparente encima del video -->
    <StackPane styleClass="overlay"/>

    <!-- Panel de progreso anclado al fondo -->
    <VBox alignment="BOTTOM_CENTER" maxWidth="Infinity" maxHeight="Infinity">
        <VBox styleClass="progress-panel" spacing="10" alignment="CENTER">
            <padding>
                <Insets top="20" bottom="24" left="40" right="40"/>
            </padding>
            <Text styleClass="titulo-carga" text="JOC DE'N PINGU"/>
            <ProgressBar fx:id="barraProgreso" prefWidth="700" prefHeight="16"
                         progress="0" styleClass="barra"/>
            <Text fx:id="textoEstado" styleClass="estado-text" text="Iniciando..."/>
        </VBox>
    </VBox>

</StackPane>
